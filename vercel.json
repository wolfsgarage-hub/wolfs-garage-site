{
  "redirects": [
    {
      "source": "/directory",
      "destination": "https://wolfs-garage-community.vercel.app",
      "permanent": false
    },
    {
      "source": "/directory/(.*)",
      "destination": "https://wolfs-garage-community.vercel.app/$1",
      "permanent": false
    },
    {
      "source": "/pages/hot-rodder-directory",
      "destination": "https://wolfs-garage-community.vercel.app",
      "permanent": false
    },
    {
      "source": "/pages/hot-rodder-directory/(.*)",
      "destination": "https://wolfs-garage-community.vercel.app/$1",
      "permanent": false
    },
    {
      "source": "/pack",
      "destination": "https://wolfs-garage-community.vercel.app",
      "permanent": false
    },
    {
      "source": "/pages/join-the-list",
      "destination": "/",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/events", "destination": "/events.html" },
    { "source": "/events/", "destination": "/events.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/events/:slug", "destination": "/api/event-page?slug=:slug" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ]
}
